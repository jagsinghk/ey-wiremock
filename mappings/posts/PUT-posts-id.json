{
  "id": "a1000001-0000-0000-0000-000000000005",
  "name": "PUT update post by ID",
  "request": {
    "method": "PUT",
    "urlPathPattern": "/posts/[0-9]+",
    "headers": {
      "Content-Type": {
        "contains": "application/json"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json; charset=utf-8",
      "Access-Control-Allow-Origin": "*"
    },
    "jsonBody": {
      "userId": 1,
      "id": 1,
      "title": "{{jsonPath request.body '$.title'}}",
      "body": "{{jsonPath request.body '$.body'}}"
    },
    "transformers": ["response-template"]
  }
}
